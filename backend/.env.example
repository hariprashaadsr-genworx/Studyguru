# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=youropenai_api_key_here
TAVILY_API_KEY=yourtavily_api_key_here

# PostgreSQL — REQUIRED in v5 (no in-memory fallback)
# Format: postgresql://user:password@host:5432/dbname
POSTGRES_DSN=your_postgres_dsn_here

# ── Strongly Recommended ──────────────────────────────────────────────────────

# Groq Vision — validates images AND generates image descriptions
# Get from: https://console.groq.com
# Free tier: 14,400 requests/day with llama-3.2-11b-vision-preview
GROQ_API_KEY=your_groq_api_key_here

# YouTube Data API v3 — fetches actual YouTube video references
# Get from: https://console.cloud.google.com → YouTube Data API v3
# Falls back to Tavily YouTube search if not set
YOUTUBE_API_KEY=your_youtube_api_key_here
